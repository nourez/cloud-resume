{
  "name": "cloud-resume",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
