{
  "name": "cloud-resume",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11.7.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev:api": "pnpm --filter @cloud-resume/api dev",
    "dev:frontend": "pnpm --filter @cloud-resume/frontend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm --filter @cloud-resume/shared-types build && pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.0.0",
    "typescript": "catalog:"
  }
}
